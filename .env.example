# Environment Variables
# Copy this file to .env and fill in your API keys

# DeepSeek API Key (Primary — very cheap, ~$0.14/1M tokens)
# Get yours at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# OpenRouter API Key (Fallback — has free models)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key-here

# Site URL (used for OpenRouter referer header)
SITE_URL=https://indrasugara.com
